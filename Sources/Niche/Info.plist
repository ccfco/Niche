<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>Niche</string>
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.utilities</string>
	<!-- menu bar accessory:不进 Dock、无主窗口(沿用 Clipin) -->
	<key>LSUIElement</key>
	<true/>
	<!-- TCC 受保护目录授权文案:权限按需触发(访问失败时),不在启动时主动弹 -->
	<key>NSDesktopFolderUsageDescription</key>
	<string>Niche 需要访问"桌面"以镜像你绑定的文件夹,方便从刘海快速取用。</string>
	<key>NSDocumentsFolderUsageDescription</key>
	<string>Niche 需要访问"文稿"以镜像你绑定的文件夹,方便从刘海快速取用。</string>
	<key>NSDownloadsFolderUsageDescription</key>
	<string>Niche 需要访问"下载"以镜像你绑定的文件夹,方便从刘海快速取用。</string>
	<!-- 「显示简介」经 Apple Events 驱动访达弹原生 Get Info 窗口(FinderGetInfo);首次发送会弹此文案授权 -->
	<key>NSAppleEventsUsageDescription</key>
	<string>Niche 需要控制"访达"来为所选文件显示简介(调起访达原生的"显示简介"窗口)。</string>
	<key>NSHumanReadableCopyright</key>
	<string>© 2026 Niche. Open source under MIT.</string>
	<!-- Sparkle 自动更新。检测由 UpdateChecker（GitHub API 轮询）负责，Sparkle 只做
	     下载/EdDSA 验签/替换/重启，故关掉它自己的定时检查（SUEnableAutomaticChecks=false）。
	     SUPublicEDKey 与 Clipin 复用同一对 EdDSA 密钥（同机同 Keychain），私钥永不轮换。 -->
	<key>SUFeedURL</key>
	<string>https://raw.githubusercontent.com/ccfco/Niche/main/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>tan1/rD5UKDwTEXAxmI/CzX/XLRQeABtgCO0uZhmFi4=</string>
	<key>SUEnableAutomaticChecks</key>
	<false/>
</dict>
</plist>
